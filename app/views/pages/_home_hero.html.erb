<section class="go-product-hero">
  <div class="go-product-hero__container">
    <div class="go-product-hero__preview">
      <%= render "pages/product_preview" %>
    </div>

    <div class="go-product-hero__content">
      <span class="go-product-hero__eyebrow">
        Atendimento inteligente para empresas
      </span>

      <h1>
        Transforme conversas em
        <span>atendimento, automação e vendas</span>
      </h1>

      <p>
        O GO ATendi centraliza canais, organiza contatos, automatiza fluxos,
        acompanha oportunidades e ajuda sua equipe a atender melhor em uma única plataforma.
      </p>

      <div class="go-product-hero__actions">
        <%= link_to "Inscrever-se", "#", class: "go-product-btn go-product-btn--primary" %>
        <%= link_to "Ver funcionalidades", "#", class: "go-product-btn go-product-btn--secondary" %>
      </div>
    </div>
  </div>
</section>
