<header class="go-mini-page-header">
  <div>
    <h3><%= title %></h3>
    <span><%= description %></span>
  </div>

  <button type="button" aria-label="<%= title %>">
    <i class="<%= icon %>"></i>
  </button>
</header>

<div class="go-mini-placeholder">
  <div class="go-mini-placeholder__icon">
    <i class="<%= icon %>"></i>
  </div>

  <strong><%= title %></strong>
  <span><%= description %></span>
</div>
