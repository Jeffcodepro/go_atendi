<% active_nav = ->(path) { current_page?(path) ? "is-active" : "" } %>

<header class="marketing-nav">
  <div class="marketing-nav__shell">
    <%= link_to root_path, class: "marketing-nav__brand", aria: { label: "Ir para a página inicial do GO ATendi" } do %>
      <span class="marketing-nav__logo-frame">
        <%= image_tag "go-atendi-logo.png", alt: "GO ATendi", class: "marketing-nav__logo" %>
      </span>
    <% end %>

    <nav class="marketing-nav__links" aria-label="Navegação principal">
      <%= link_to "Soluções", solucoes_path, class: "marketing-nav__link #{active_nav.call(solucoes_path)}" %>
      <%= link_to "Funcionalidades", funcionalidades_path, class: "marketing-nav__link #{active_nav.call(funcionalidades_path)}" %>
      <%= link_to "Resultado", resultado_path, class: "marketing-nav__link #{active_nav.call(resultado_path)}" %>
      <%= link_to "Preço", preco_path, class: "marketing-nav__link #{active_nav.call(preco_path)}" %>
    </nav>

    <div class="marketing-nav__actions">
      <%= link_to "Inscrever-se", inscricao_path, class: "btn btn--primary btn--nav #{active_nav.call(inscricao_path)}" %>
      <%= link_to "Entrar", entrar_path, class: "btn btn--ghost btn--nav #{active_nav.call(entrar_path)}" %>
    </div>

    <details class="marketing-nav__mobile">
      <summary class="marketing-nav__mobile-button" aria-label="Abrir menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <div class="marketing-nav__mobile-panel">
        <%= link_to "Soluções", solucoes_path, class: "marketing-nav__mobile-link #{active_nav.call(solucoes_path)}" %>
        <%= link_to "Funcionalidades", funcionalidades_path, class: "marketing-nav__mobile-link #{active_nav.call(funcionalidades_path)}" %>
        <%= link_to "Resultado", resultado_path, class: "marketing-nav__mobile-link #{active_nav.call(resultado_path)}" %>
        <%= link_to "Preço", preco_path, class: "marketing-nav__mobile-link #{active_nav.call(preco_path)}" %>

        <div class="marketing-nav__mobile-actions">
          <%= link_to "Inscrever-se", inscricao_path, class: "btn btn--primary btn--full" %>
          <%= link_to "Entrar", entrar_path, class: "btn btn--ghost btn--full" %>
        </div>
      </div>
    </details>
  </div>
</header>
